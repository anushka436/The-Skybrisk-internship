# Temperature Converter

celsius = float(input("Enter temperature in Celsius: "))
fahrenheit = (celsius * 9/5) + 32
print("Temperature in Fahrenheit is:", fahrenheit)


# Simple Calculator

num1 = float(input("Enter first number: "))
num2 = float(input("Enter second number: "))
operator = input("Enter operator (+, -, *, /): ")

if operator == "+":
    print("Result:", num1 + num2)

elif operator == "-":
    print("Result:", num1 - num2)

elif operator == "*":
    print("Result:", num1 * num2)

elif operator == "/":
    print("Result:", num1 / num2)

else:
    print("Invalid operator")

# Average Temperature Calculation

temp1 = float(input("Enter temperature of day 1: "))
temp2 = float(input("Enter temperature of day 2: "))
temp3 = float(input("Enter temperature of day 3: "))
temp4 = float(input("Enter temperature of day 4: "))
temp5 = float(input("Enter temperature of day 5: "))
average = (temp1 + temp2 + temp3 + temp4 + temp5) / 5
print("Average temperature is:", average)

